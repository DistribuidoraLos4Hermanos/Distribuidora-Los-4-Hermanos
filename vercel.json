{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "routes": [
    { "src": "/admin", "dest": "/z-admin.html" },
    { "src": "/api/products/([^/]+)", "dest": "/[id].js" },
    { "src": "/api/products", "dest": "/products.js" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
