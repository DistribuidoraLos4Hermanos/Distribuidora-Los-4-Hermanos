{
  "version": 2,
  "routes": [
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/api/products/([^/]+)", "dest": "/api/products/[id].js" },
    { "src": "/api/products", "dest": "/api/products.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
