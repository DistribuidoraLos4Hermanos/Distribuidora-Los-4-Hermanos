{
  "version": 2,
  "public": true,
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/api/products/:id", "destination": "/api/products/[id].js" },
    { "source": "/api/products", "destination": "/api/products.js" }
  ],
  "headers": [
    {
      "source": "/admin.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
